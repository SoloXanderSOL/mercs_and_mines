# Copy this file to .env and adjust values as needed.
# All variables have safe defaults baked into Config::from_env() — .env is optional.

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_BIND_ADDR=0.0.0.0:3000          # TCP address:port the Axum server binds to
LOG_DIR=./logs                          # Directory for session NDJSON logs
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=f5dac291-d72f-4a24-bae8-1b290e98c3b4  # Helius devnet RPC endpoint

# ── Auth / Session ────────────────────────────────────────────────────────────
SESSION_DURATION_SECS=7200             # TEEPIN session window (7200 = 2 hours)
CHALLENGE_EXPIRY_SECS=60              # Seconds before an unsigned challenge expires
COMBAT_SESSION_STALE_SECS=300         # Seconds before a queued WS session is rejected

# ── Combat ─────────────────────────────────────────────────────────────────────
DEFAULT_MAX_TICKS=50                   # Default tick cap when client omits max_ticks
TICK_STREAM_DELAY_MS=750              # Milliseconds between streamed CombatTickEvents

# ── Mission Resolver: Damage ───────────────────────────────────────────────────
HP_LOSS_MULT_SUCCESS=0.4              # HP-loss chance multiplier on success (softens)
HP_LOSS_MULT_FAILURE=1.5              # HP-loss chance multiplier on failure (hardens)
HP_LOSS_CLAMP_MIN=2.0                 # Minimum effective HP-loss chance after shield (%)
HP_ROLL_SUCCESS_THRESHOLD=60          # d100 <= this → 1 HP lost on success; else 2
HP_ROLL_FAILURE_THRESHOLD=40          # d100 <= this → 2 HP lost on failure; else 3
KIA_BASE_CHANCE_SUCCESS=10.0          # Base KIA chance (%) on successful missions
KIA_BASE_CHANCE_FAILURE=35.0          # Base KIA chance (%) on failed missions
SAWBONES_TRAUMA_CHANCE=0.30           # Sawbones: chance to convert KIA → Wounded

# ── Mission Resolver: Outcome ─────────────────────────────────────────────────
OUTCOME_MARGIN_THRESHOLD=25.0         # Margin separating Full/Wipeout from Partial/Retreat
FULL_SUCCESS_REWARD_MULT=1.5          # Credit + ore multiplier on Full Success

# ── Mission Score ─────────────────────────────────────────────────────────────
SQUAD_SIZE_BONUS_PER_UNIT=3           # Score bonus per additional squad member
BASE_SKILL_SCORE_WEIGHT=50.0          # Weight converting normalised skill to score points

# ── Unit Ability Bonuses ──────────────────────────────────────────────────────
GHOST_WIRE_MISSION_BONUS=7            # GhostWire: Sabotage / Extraction mission bonus
TUNNEL_RUNNER_ENV_BONUS=8             # TunnelRunner: Underground environment bonus
PROSPECTOR_EXTRACTION_BONUS=5         # Prospector: Extraction mission bonus
PYROCLAST_INDUSTRIAL_BONUS=15         # Pyroclast: Industrial environment bonus (removes penalty)
VANGUARD_STACK_BONUS_PER_UNIT=2       # Vanguard: bonus per additional Vanguard in squad
MAX_VANGUARD_STACK_BONUS=6            # Vanguard: total cap on stacking bonus

# ── Commander Stress ──────────────────────────────────────────────────────────
DEPLOYMENT_STRESS_PENALTY=10          # Stress added per mission deployment
CASUALTY_STRESS_PENALTY=5             # Stress added per casualty during combat

# ── Loot Roller ───────────────────────────────────────────────────────────────
MAX_LOOT_BONUS_CAP=50                 # Max loot_bonus accepted (prevents Elite spam)
LOOT_DRAIN_MULTIPLIER=1.5             # Points drained from Basic weight per bonus point
LOOT_BASIC_WEIGHT_MIN=5.0             # Floor weight for Basic grade (prevents zero)
LOOT_STANDARD_UPLIFT_FRAC=0.4        # Fraction of uplift → Standard grade
LOOT_SPECIALIZED_UPLIFT_FRAC=0.3     # Fraction of uplift → Specialized grade
LOOT_SUPERIOR_UPLIFT_FRAC=0.2        # Fraction of uplift → Superior grade
LOOT_ELITE_UPLIFT_FRAC=0.1           # Fraction of uplift → Elite grade (keep small)
LOOT_DROP_CHANCE_BASE=40              # Base loot drop chance (%) before difficulty scaling
LOOT_DROP_CHANCE_PER_DIFF=4          # Additional drop chance (%) per difficulty tier

# ── Units ─────────────────────────────────────────────────────────────────────
UNIT_DEFAULT_HP=10                    # Starting current_hp and max_hp for new merc units
